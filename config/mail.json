{
  "smtp": [
    {
      "name": "default",
      "host": "smtp.gmail.com",
      "port": 587,
      "use_tls": true,
      "use_ssl": false,
      "user": "",
      "password_env": "SMTP_PASSWORD",
      "from_address": "",
      "from_name": "LangGraph Agent"
    }
  ],

  "imap": [
    {
      "name": "default",
      "host": "imap.gmail.com",
      "port": 993,
      "use_ssl": true,
      "user": "",
      "password_env": "IMAP_PASSWORD"
    }
  ],

  "listener": {
    "poll_interval": 15,
    "allowed_senders": [],
    "ignore_patterns": [
      "noreply@",
      "no-reply@",
      "mailer-daemon@"
    ]
  },

  "templates": [
    {
      "name": "notification",
      "subject": "LangGraph — Notification",
      "body": ""
    },
    {
      "name": "question",
      "subject": "[LangGraph] {agent_name} — Question",
      "body": ""
    },
    {
      "name": "approval",
      "subject": "[LangGraph] {agent_name} — Validation requise",
      "body": "Repondez avec UN des mots suivants en debut de message :\n\n  approve  → valider et continuer\n  revise   → demander des modifications\n  reject   → rejeter"
    },
    {
      "name": "reminder",
      "subject": "Rappel : {agent_name} — Validation requise",
      "body": ""
    },
    {
      "name": "footer",
      "subject": "",
      "body": "LangGraph Multi-Agent Platform"
    }
  ],

  "security": {
    "require_tls": true,
    "verify_sender": true,
    "max_body_size": 50000
  },

  "presets": {
    "gmail": {
      "smtp": {"host": "smtp.gmail.com", "port": 587, "use_tls": true, "use_ssl": false},
      "imap": {"host": "imap.gmail.com", "port": 993, "use_ssl": true},
      "notes": "Utiliser un App Password (pas le mot de passe principal). Activer IMAP dans les parametres Gmail."
    },
    "outlook": {
      "smtp": {"host": "smtp.office365.com", "port": 587, "use_tls": true, "use_ssl": false},
      "imap": {"host": "outlook.office365.com", "port": 993, "use_ssl": true},
      "notes": "Activer IMAP/SMTP dans les parametres Outlook. OAuth2 peut etre requis pour les comptes entreprise."
    },
    "ovh": {
      "smtp": {"host": "ssl0.ovh.net", "port": 465, "use_tls": false, "use_ssl": true},
      "imap": {"host": "ssl0.ovh.net", "port": 993, "use_ssl": true},
      "notes": "Mot de passe email standard."
    },
    "infomaniak": {
      "smtp": {"host": "mail.infomaniak.com", "port": 587, "use_tls": true, "use_ssl": false},
      "imap": {"host": "mail.infomaniak.com", "port": 993, "use_ssl": true},
      "notes": "Mot de passe email standard."
    }
  }
}
