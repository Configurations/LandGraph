        {"name": "Alertes", "output_key": "alerts", "instruction": "Alertes: info/warning/critical. Critical = bloquant. Format: {\"alerts\": [{\"level\":\"...\",\"category\":\"...\",\"description\":\"...\",\"recommendation\":\"...\"}]}"}
